<div class="row mb-3">
  <h1><i class="bi bi-0-circle"></i> Pokémons </h1>
  <hr />
</div>
<div class="row mb-3">
  <div class="col-12">
    <a href="/pokemons/create" class="btn btn-success">
      <i class="bi bi-plus-circle"></i> Nuevo Pokémon
    </a>
  </div>


{{#if hasPokemons}}
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    {{#each pokemons}}
      <div class="col">
        <div class="card h-100 border-0 shadow-sm">
          <div class="text-center pt-3" style="background-color: #f0f0f0; border-radius: 8px 8px 0 0;">
            <img
              src="{{this.photo}}"
              alt="{{this.name}}"
              style="height: 130px; object-fit: contain;"
              onerror="this.src='https://placehold.co/130x130?text=?'"
            />
          </div>
          <div class="card-body">
            <h5 class="card-title text-capitalize mb-1">{{this.name}}</h5>
            <p class="text-muted small mb-0">
              <i class="bi bi-tag me-1"></i>
              {{#if this.PokemonType}}{{this.PokemonType.name}}{{else}}Sin tipo{{/if}}
            </p>
            <p class="text-muted small">
              <i class="bi bi-geo-alt me-1"></i>
              {{#if this.Region}}{{this.Region.name}}{{else}}Sin región{{/if}}
            </p>
          </div>
          <div class="card-footer bg-white border-0 d-flex gap-2 pb-3">
            <a href="/pokemons/edit/{{this.id}}" class="btn btn-outline-primary btn-sm w-50">
              <i class="bi bi-pencil"></i> Editar
            </a>
            <form method="post" action="/pokemons/delete" class="w-50">
              <input type="hidden" name="id" value="{{this.id}}" />
              <button type="submit" class="btn btn-outline-danger btn-sm w-100 confirm-delete">
                <i class="bi bi-trash3"></i> Eliminar
              </button>
            </form>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="text-center py-5 text-muted">
    <i class="bi bi-inbox display-4"></i>
    <p class="mt-3">No hay pokémons registrados todavía.</p>
  </div>
{{/if}}

{{#section "scripts"}}
<script>
  document.querySelectorAll(".confirm-delete").forEach((btn) => {
    btn.addEventListener("click", function (e) {
      if (!confirm("¿Seguro que deseas eliminar este Pokémon?")) {
        e.preventDefault();
      }
    });
  });
</script>
{{/section}}