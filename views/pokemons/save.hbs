<div class="row mb-3">
  <h1>{{#if editMode}}Editar Pokémon{{else}}Crear Pokémon{{/if}}</h1>
  <hr />
</div>

<div class="row d-flex justify-content-center">
  <div class="col-12 col-sm-7">

    {{#if error}}
      <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> {{error}}</div>
    {{/if}}

    <div class="card shadow-sm">
      <div class="card-body">
        <form method="post" action="/pokemons/{{#if editMode}}edit/{{pokemon.id}}{{else}}create{{/if}}">

          <div class="mb-3">
            <label for="name" class="form-label fw-semibold">Nombre del Pokémon</label>
            <input type="text" id="name" name="name" class="form-control"
              placeholder="Ej: Pikachu"
              value="{{#if editMode}}{{pokemon.name}}{{else}}{{formData.name}}{{/if}}" required />
          </div>
           <div class="mb-3">
            <label for="photo" class="form-label fw-semibold">Foto del Pokémon</label>
            <input type="text" id="photo" name="photo" class="form-control"
              placeholder="Ej: pikachu.png"
              value="{{#if editMode}}{{pokemon.photo}}{{else}}{{formData.photo}}{{/if}}" required />
          </div>
            <div class="mb-3">
            <label for="typeId" class="form-label">Tipo de pokemón:</label>
            <select id="typeId"  class="form-select" name="typeId">
              <option value="">Seleccionar opción</option>
           {{#each types}}
              <option value="{{this.id}}" {{#if (eq this.id ../pokemon.typeId)}}selected{{/if}}>{{this.name}}</option>
            {{/each}}
            </select>
          </div> 
          <div class="mb-3">
              <label for="regionId" class="form-label fw-semibold">Región</label>
              <select id="regionId" class="form-select" name="regionId">
                <option value="">Seleccionar opción</option>
                {{#each regions}}
                  <option value="{{this.id}}" {{#if (eq this.id ../pokemon.regionId)}}selected{{/if}}>{{this.name}}</option>
                {{/each}}
              </select>
          </div>
          <div class="d-flex gap-2 mt-4">
            <a href="/pokemons/index" class="btn btn-secondary">
              <i class="bi bi-arrow-left"></i> Volver
            </a>
            <button type="submit" class="btn btn-{{#if editMode}}primary{{else}}success{{/if}}">
              <i class="bi bi-check-circle"></i>
              {{#if editMode}}Guardar cambios{{else}}Crear Pokémon{{/if}}
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>