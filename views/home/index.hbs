<div class="row mb-3">
    <h1><i class="bi bi-0-circle"></i> Pokémons </h1>
    <hr />
</div>
<div class="row mb-3">
    <form action="/" method="get" class="row g-3 align-items-end mb-4">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-3">
                <label for="searchTerm" class="form-label fw-semibold">Buscar por nombre</label>
                <input type="text" id="searchTerm" name="searchTerm" class="form-control" placeholder="Ej: pikachu"
                    value="{{formData.searchTerm}}" />
            </div>
            <div class="col-12 col-sm-3">
                <label for="typeId" class="form-label fw-semibold">Filtrar por tipo</label>
                <select id="typeId" name="typeId" class="form-select">
                    <option value="">Todos los tipos</option>
                    {{#each types}}
                    <option value="{{this.id}}" {{#if (eq this.id ../formData.typeId)}}selected{{/if}}>{{this.name}}</option>
                    {{/each}}
                </select>
            </div>
              <div class="col-12 col-sm-3">
                <label for="regionId" class="form-label fw-semibold">Filtrar por región</label>
                <select id="regionId" name="regionId" class="form-select">
                    <option value="">Todas las regiones</option>
                    {{#each regions}}
                    <option value="{{this.id}}"{{#if (eq this.id ../formData.regionId)}}selected{{/if}}>{{this.name}}</option>
                    {{/each}}
                </select>
            </div>
              <div class="col-12 col-sm-3 mt-4">
                <button type="submit" class="btn btn-outline-dark w-50">
                    <i class="bi bi-search"></i> Filtrar
                </button>
            </div>
            </div>
    </form>

</div>

    {{#if hasPokemons}}
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        {{#each pokemons}}
        <div class="col">
            <div class="card h-100 border-0 shadow-sm">
                <div class="text-center pt-3" style="background-color: #f0f0f0; border-radius: 8px 8px 0 0;">
                    <img src="{{this.photo}}" alt="{{this.name}}" style="height: 130px; object-fit: contain;"
                        onerror="this.src='https://placehold.co/130x130?text=?'" />
                </div>
                <div class="card-body">
                    <h5 class="card-title text-capitalize mb-1">{{this.name}}</h5>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-tag me-1"></i>
                        {{#if this.PokemonType}}{{this.PokemonType.name}}{{else}}Sin tipo{{/if}}
                    </p>
                    <p class="text-muted small">
                        <i class="bi bi-geo-alt me-1"></i>
                        {{#if this.Region}}{{this.Region.name}}{{else}}Sin región{{/if}}
                    </p>
                </div>
                </div>
            </div>
        {{/each}}
    </div>
    {{else}}
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox display-4"></i>
        <p class="mt-3">No hay pokémons registrados</p>
    </div>
    {{/if}}

    {{#section "scripts"}}
    <script>
        document.querySelectorAll(".confirm-delete").forEach((btn) => {
            btn.addEventListener("click", function (e) {
                if (!confirm("¿Seguro que deseas eliminar este Pokémon?")) {
                    e.preventDefault();
                }
            });
        });
    </script>
    {{/section}}