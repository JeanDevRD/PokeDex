<div class="row mb-3">
  <h1><i class="bi bi-geo-alt"></i> Regiones</h1>
  <hr />
</div>

<div class="row mb-3">
  <div class="col-12">
    <a href="/regions/create" class="btn btn-success">
      <i class="bi bi-plus-circle"></i> Nueva región
    </a>
  </div>
</div>

{{#if hasRegions}}
<div class="row">
  {{#each regions}}
  <div class="col-12 col-sm-4 col-md-3 mb-3">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-tag-fill"></i> {{this.name}}</h5>
        <div class="mt-3 d-flex gap-2">
          <a href="/regions/edit/{{this.id}}" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil"></i> Editar
          </a>
          <a href="/regions/delete/{{this.id}}" class="btn btn-danger btn-sm">
            <i class="bi bi-trash3"></i> Eliminar
          </a>
          </form>
        </div>
      </div>
    </div>
  </div>
  {{/each}}
</div>
{{else}}
<div class="row d-flex justify-content-center">
  <div class="col-12 col-sm-5">
    <div class="alert alert-info">
      <i class="bi bi-info-circle"></i> No hay géneros registrados.
    </div>
  </div>
</div>
{{/if}}

{{#section "scripts"}}
<script>
  document.querySelectorAll(".confirm-delete").forEach((btn) => {
    btn.addEventListener("click", function (e) {
      if (!confirm(`¿Está seguro que desea eliminar este género?`)) {
        e.preventDefault();
      }
    });
  });
</script>
{{/section}}